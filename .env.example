# ShieldCar — variables de entorno
# Copia este archivo a `.env.local` y llena los valores reales.
# `.env*` está en .gitignore: las llaves JAMÁS entran al repo.

# URL del proyecto Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Llave pública (anon) — para el cliente del navegador (Fase 2)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Llave service_role — SOLO servidor (salta RLS; nunca la expongas al cliente)
SUPABASE_SERVICE_ROLE_KEY=
